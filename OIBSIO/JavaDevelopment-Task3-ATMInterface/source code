import java.time.LocalDateTime;
import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.Scanner;

public class Main {
    
    public static void main(String[] args) {
        Bank centralBank = new Bank();

        // Seed some starting accounts for testing
        centralBank.addAccount(new Account("kumar123", "4321", 1500.00));
        centralBank.addAccount(new Account("shree789", "1111", 500.50));
        centralBank.addAccount(new Account("hima55", "9999", 50.00));

        Scanner scanner = new Scanner(System.in);
        ATM atm = new ATM(centralBank, scanner);
        
        atm.start();
        scanner.close();
    }

    // ==========================================
    // 1. TRANSACTION CLASS
    // ==========================================
    public static class Transaction {
        private final String type;
        private final double amount;
        private final LocalDateTime timestamp;
        private final String details;

        public Transaction(String type, double amount, String details) {
            this.type = type;
            this.amount = amount;
            this.timestamp = LocalDateTime.now();
            this.details = details;
        }

        @Override
        public String toString() {
            DateTimeFormatter formatter = DateTimeFormatter.ofPattern("yyyy-MM-dd HH:mm:ss");
            return String.format("[%s] %-12s: $%8.2f (%s)", 
                    timestamp.format(formatter), type, amount, details);
        }
    }

    // ==========================================
    // 2. ACCOUNT CLASS
    // ==========================================
    public static class Account {
        private final String userId;
        private final String pin;
        private double balance;
        private final List<Transaction> transactionHistory;

        public Account(String userId, String pin, double initialBalance) {
            this.userId = userId;
            this.pin = pin;
            this.balance = initialBalance;
            this.transactionHistory = new ArrayList<>();
        }

        public String getUserId() { return userId; }
        public double getBalance() { return balance; }

        public boolean validatePin(String enteredPin) {
            return this.pin.equals(enteredPin);
        }

        public void deposit(double amount, String details) {
            balance += amount;
            transactionHistory.add(new Transaction("DEPOSIT", amount, details));
        }

        public boolean withdraw(double amount, String details) {
            if (amount > balance) {
                return false;
            }
            balance -= amount;
            transactionHistory.add(new Transaction("WITHDRAWAL", amount, details));
            return true;
        }

        public void printHistory() {
            if (transactionHistory.isEmpty()) {
                System.out.println("No transactions recorded in this session.");
                return;
            }
            System.out.println("\n--- TRANSACTION HISTORY ---");
            for (Transaction t : transactionHistory) {
                System.out.println(t);
            }
            System.out.printf("Current Balance: $%.2f\n", balance);
        }
    }

    // ==========================================
    // 3. BANK CLASS
    // ==========================================
    public static class Bank {
        private final Map<String, Account> accounts = new HashMap<>();

        public void addAccount(Account account) {
            accounts.put(account.getUserId(), account);
        }

        public Account getAccount(String userId) {
            return accounts.get(userId);
        }

        public boolean transfer(Account source, String targetId, double amount) {
            Account target = getAccount(targetId);
            if (target == null) {
                System.out.println("Error: Recipient account not found.");
                return false;
            }
            if (source.getUserId().equals(targetId)) {
                System.out.println("Error: You cannot transfer money to yourself.");
                return false;
            }

            if (source.withdraw(amount, "Transfer to " + targetId)) {
                target.deposit(amount, "Transfer from " + source.getUserId());
                return true;
            }
            return false;
        }
    }

    // ==========================================
    // 4. ATM CLASS
    // ==========================================
    public static class ATM {
        private final Bank bank;
        private final Scanner scanner;
        private Account currentAccount;

        public ATM(Bank bank, Scanner scanner) {
            this.bank = bank;
            this.scanner = scanner;
        }

        public void start() {
            System.out.println("Welcome to the Automated Teller Machine.");
            if (authenticateUser()) {
                showMainMenu();
            } else {
                System.out.println("\nAccess Denied. Too many incorrect attempts. Exiting...");
            }
        }

        private boolean authenticateUser() {
            int attempts = 0;
            final int MAX_ATTEMPTS = 3;

            while (attempts < MAX_ATTEMPTS) {
                System.out.print("\nEnter User ID: ");
                String userId = scanner.nextLine().trim();
                System.out.print("Enter PIN: ");
                String pin = scanner.nextLine().trim();

                Account account = bank.getAccount(userId);
                if (account != null && account.validatePin(pin)) {
                    currentAccount = account;
                    System.out.printf("\nAuthentication Successful. Welcome, %s!\n", userId);
                    return true;
                }

                attempts++;
                System.out.printf("Invalid ID or PIN. Attempts remaining: %d\n", (MAX_ATTEMPTS - attempts));
            }
            return false;
        }

        private void showMainMenu() {
            boolean quit = false;
            while (!quit) {
                System.out.println("\n===== MAIN MENU =====");
                System.out.println("1. Transaction History");
                System.out.println("2. Withdraw");
                System.out.println("3. Deposit");
                System.out.println("4. Transfer");
                System.out.println("5. Quit");
                System.out.print("Choose an option: ");

                String choice = scanner.nextLine().trim();
                switch (choice) {
                    case "1" -> currentAccount.printHistory();
                    case "2" -> handleWithdrawal();
                    case "3" -> handleDeposit();
                    case "4" -> handleTransfer();
                    case "5" -> {
                        System.out.println("\nThank you for banking with us. Goodbye!");
                        quit = true;
                    }
                    default -> System.out.println("Invalid option. Please choose 1-5.");
                }
            }
        }

        private void handleWithdrawal() {
            System.out.printf("Available Balance: $%.2f\n", currentAccount.getBalance());
            System.out.print("Enter withdrawal amount: $");
            double amount = getValidAmount();
            if (amount <= 0) return;

            if (currentAccount.withdraw(amount, "ATM Cash Withdrawal")) {
                System.out.printf("Please take your cash. New balance: $%.2f\n", currentAccount.getBalance());
            } else {
                System.out.println("Insufficient Funds.");
            }
        }

        private void handleDeposit() {
            System.out.print("Enter deposit amount: $");
            double amount = getValidAmount();
            if (amount <= 0) return;

            currentAccount.deposit(amount, "ATM Cash Deposit");
            System.out.printf("Deposit accepted. New balance: $%.2f\n", currentAccount.getBalance());
        }

        private void handleTransfer() {
            System.out.print("Enter recipient Account ID: ");
            String recipientId = scanner.nextLine().trim();
            System.out.print("Enter transfer amount: $");
            double amount = getValidAmount();
            if (amount <= 0) return;

            if (bank.transfer(currentAccount, recipientId, amount)) {
                System.out.printf("Transfer successful! New balance: $%.2f\n", currentAccount.getBalance());
            } else {
                System.out.println("Transfer Failed: Check balance or recipient ID.");
            }
        }

        private double getValidAmount() {
            try {
                double amount = Double.parseDouble(scanner.nextLine().trim());
                if (amount <= 0) {
                    System.out.println("Amount must be greater than zero.");
                    return -1;
                }
                return amount;
            } catch (NumberFormatException e) {
                System.out.println("Invalid numeric input.");
                return -1;
            }
        }
    }
}
